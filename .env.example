# ─── Database ──────────────────────────────────────────────────────────────
# Docker-compose Postgres binds to host port 5433 to avoid clashing with a
# system Postgres install. asyncpg URL for the app, sync URL for Alembic.
DATABASE_URL=postgresql+asyncpg://flowprov:flowprov_dev_pw@localhost:5433/flowprov
DATABASE_URL_SYNC=postgresql+psycopg2://flowprov:flowprov_dev_pw@localhost:5433/flowprov

# ─── API server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ─── Embeddings ────────────────────────────────────────────────────────────
# "hash"   — dependency-free default. Fast, deterministic, character+word
#            n-gram hashing into 384-dim. Plenty good for drift detection.
# "minilm" — real sentence-transformers/all-MiniLM-L6-v2. Higher fidelity
#            but requires `pip install -e ".[ml]"` (pulls torch ~1.5GB).
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─── LLM client ────────────────────────────────────────────────────────────
# Set to "fake" to run fully offline (default — perfect for the demo).
# Set to "openai" and provide OPENAI_API_KEY to use the real OpenAI API.
LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Drift detection thresholds ────────────────────────────────────────────
# Hard fail: cosine distance > this triggers an immediate alert regardless of class history.
DRIFT_HARD_THRESHOLD=0.40
# Soft warn: trigger if distance > mean + N*std of historical in-class distances.
DRIFT_SOFT_STD_MULTIPLIER=2.5
# Minimum historical samples required before soft-warn becomes active.
DRIFT_MIN_HISTORY=5
# k-nearest neighbors to compare against.
DRIFT_KNN=10

# ─── Notifications (optional) ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=
